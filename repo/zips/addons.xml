        <license>Apache-2.0</license>
        <forum />
        <website>https://www.github.com/drinfernoo</website>
        <email />
        <source />
        <news />
        <disclaimer />
        <assets>
            <icon>resources/31.jpg</icon>
        </assets>
    </extension>
</addon></addons>