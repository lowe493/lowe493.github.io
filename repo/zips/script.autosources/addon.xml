<addon id="script.autosources"
       name="Auto Sources Safe Sync"
       version="1.0.2"
       provider-name="lowe493">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.service" library="service.py">
        <provides>executable</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Safe Auto Sources Sync</summary>
        <description>Atomic, backup-safe sources.xml editor (files only)</description>
        <platform>all</platform>
    </extension>

</addon>
